SHELL := /bin/bash

ROOT_DIR := $(CURDIR)
VENV := .venv
PYTHON := python3
PIP := $(VENV)/bin/pip
PY := $(VENV)/bin/python
UVICORN := $(VENV)/bin/uvicorn
NPM := npm
MAKEFILE_NAME := Makefile.dev

FX_DIR := services/fx_insights
FX_BACKEND_MODULE := services.fx_insights.backend.local_server
FX_FRONTEND_DIR := $(FX_DIR)/frontend
FX_SETUP_SCRIPT := $(FX_DIR)/setup_local.sh
FX_BACKEND_PORT := 5001
FX_FRONTEND_PORT := 5173
FX_DOCKER_IMAGE := fx-insights-local

SEM_DIR := services/semantic_patient_search
SEM_BACKEND_MODULE := services.semantic_patient_search.backend.local_server
SEM_FRONTEND_DIR := $(SEM_DIR)/frontend
SEM_SETUP_SCRIPT := $(SEM_DIR)/setup_local.sh
SEM_BACKEND_PORT := 5002
SEM_FRONTEND_PORT := 5174
SEM_DOCKER_IMAGE := semantic-patient-search-local

TRIAL_DIR := services/clinical_trial_matching_agent
TRIAL_API_DIR := $(TRIAL_DIR)/apps/api
TRIAL_WEB_DIR := $(TRIAL_DIR)/apps/web
TRIAL_API_REQUIREMENTS := $(TRIAL_API_DIR)/requirements.txt
TRIAL_BACKEND_PORT := 8000
TRIAL_FRONTEND_PORT := 3000
TRIAL_FRONTEND_ROUTE := /projects/clinical-trial-matching-agent
TRIAL_DOCKER_IMAGE := clinical-trial-matching-agent-local

CUSTOMER_DIR := services/customer-lifecycle-agent
CUSTOMER_API_DIR := $(CUSTOMER_DIR)/api
CUSTOMER_WEB_DIR := $(CUSTOMER_DIR)/apps/web
CUSTOMER_BACKEND_PORT := 8010
CUSTOMER_FRONTEND_PORT := 3001
CUSTOMER_FRONTEND_ROUTE := /projects/customer-lifecycle-agent

.DEFAULT_GOAL := help

help:
	@echo "Available dev commands:"
	@echo "  make -f $(MAKEFILE_NAME) setup              - create root venv and install root requirements"
	@echo "  make -f $(MAKEFILE_NAME) install            - install/update root requirements"
	@echo "  make -f $(MAKEFILE_NAME) gateway            - run FastAPI gateway on port 8080"
	@echo "  make -f $(MAKEFILE_NAME) resume             - run Resume Analyzer directly"
	@echo "  make -f $(MAKEFILE_NAME) fx-setup           - prepare FX local environment"
	@echo "  make -f $(MAKEFILE_NAME) fx-install         - install FX frontend dependencies"
	@echo "  make -f $(MAKEFILE_NAME) fx-backend         - run FX backend locally on port $(FX_BACKEND_PORT)"
	@echo "  make -f $(MAKEFILE_NAME) fx-frontend        - run FX frontend locally on port $(FX_FRONTEND_PORT)"
	@echo "  make -f $(MAKEFILE_NAME) fx                 - setup and run FX backend + frontend together"
	@echo "  make -f $(MAKEFILE_NAME) fx-build           - build FX Insights Docker image locally"
	@echo "  make -f $(MAKEFILE_NAME) fx-docker-run      - run FX Insights Docker container locally"
	@echo "  make -f $(MAKEFILE_NAME) fx-smoke           - quick local health checks for FX endpoints"
	@echo "  make -f $(MAKEFILE_NAME) semantic-setup     - prepare Semantic Search local environment"
	@echo "  make -f $(MAKEFILE_NAME) semantic-install   - install Semantic Search frontend dependencies"
	@echo "  make -f $(MAKEFILE_NAME) semantic-backend   - run Semantic Search backend locally on port $(SEM_BACKEND_PORT)"
	@echo "  make -f $(MAKEFILE_NAME) semantic-frontend  - run Semantic Search frontend locally on port $(SEM_FRONTEND_PORT)"
	@echo "  make -f $(MAKEFILE_NAME) semantic           - setup and run Semantic Search backend + frontend together"
	@echo "  make -f $(MAKEFILE_NAME) semantic-build     - build Semantic Search Docker image locally"
	@echo "  make -f $(MAKEFILE_NAME) semantic-docker-run - run Semantic Search Docker container locally"
	@echo "  make -f $(MAKEFILE_NAME) semantic-smoke     - quick local health checks for Semantic Search endpoints"
	@echo "  make -f $(MAKEFILE_NAME) thermo             - run Smart Thermostat directly"
	@echo "  make -f $(MAKEFILE_NAME) trial-setup        - install Clinical Trial backend Python requirements"
	@echo "  make -f $(MAKEFILE_NAME) trial-install      - install Clinical Trial backend + frontend dependencies"
	@echo "  make -f $(MAKEFILE_NAME) trial-backend      - run Clinical Trial backend locally on port $(TRIAL_BACKEND_PORT)"
	@echo "  make -f $(MAKEFILE_NAME) trial-frontend     - run Clinical Trial frontend locally on port $(TRIAL_FRONTEND_PORT)"
	@echo "  make -f $(MAKEFILE_NAME) trial              - run Clinical Trial backend + frontend together"
	@echo "  make -f $(MAKEFILE_NAME) trial-smoke        - quick local health checks for Clinical Trial endpoints"
	@echo "  make -f $(MAKEFILE_NAME) trial-stop         - kill Clinical Trial frontend/backend ports"
	@echo "  make -f $(MAKEFILE_NAME) customer-setup     - install Customer Lifecycle backend Python requirements"
	@echo "  make -f $(MAKEFILE_NAME) customer-install   - install Customer Lifecycle backend + frontend dependencies"
	@echo "  make -f $(MAKEFILE_NAME) customer-backend   - run Customer Lifecycle backend locally on port $(CUSTOMER_BACKEND_PORT)"
	@echo "  make -f $(MAKEFILE_NAME) customer-frontend  - run Customer Lifecycle frontend locally on port $(CUSTOMER_FRONTEND_PORT)"
	@echo "  make -f $(MAKEFILE_NAME) customer           - run Customer Lifecycle backend + frontend together"
	@echo "  make -f $(MAKEFILE_NAME) customer-smoke     - quick local health checks for Customer Lifecycle endpoints"
	@echo "  make -f $(MAKEFILE_NAME) customer-stop      - kill Customer Lifecycle frontend/backend ports"
	@echo "  make -f $(MAKEFILE_NAME) check              - verify key packages are installed"
	@echo "  make -f $(MAKEFILE_NAME) clean              - remove root virtual environment"
	@echo "  make -f $(MAKEFILE_NAME) fx-clean           - remove FX frontend node_modules/dist"
	@echo "  make -f $(MAKEFILE_NAME) semantic-clean     - remove Semantic Search frontend node_modules/dist"
	@echo "  make -f $(MAKEFILE_NAME) trial-clean        - remove Clinical Trial frontend node_modules/.next"
	@echo "  make -f $(MAKEFILE_NAME) customer-clean     - remove Customer Lifecycle frontend node_modules/.next"

$(VENV)/bin/activate:
	$(PYTHON) -m venv $(VENV)
	$(PIP) install --upgrade pip
	$(PIP) install -r requirements.txt

setup: $(VENV)/bin/activate

install: $(VENV)/bin/activate
	$(PIP) install -r requirements.txt

gateway: $(VENV)/bin/activate
	PYTHONPATH=. $(UVICORN) gateway.main:app --port 8080 --reload

resume: $(VENV)/bin/activate
	PYTHONPATH=. $(PY) -m services.resume_job_analyzer.app

fx-setup: $(VENV)/bin/activate
	chmod +x $(FX_SETUP_SCRIPT)
	cd $(FX_DIR) && ./setup_local.sh

fx-install: $(VENV)/bin/activate
	cd $(FX_FRONTEND_DIR) && $(NPM) install

fx-backend: $(VENV)/bin/activate
	PYTHONPATH=. $(PY) -m $(FX_BACKEND_MODULE)

fx-frontend:
	cd $(FX_FRONTEND_DIR) && $(NPM) run dev

fx: fx-setup
	@echo "FX Insights is starting..."
	@echo "Frontend: http://127.0.0.1:$(FX_FRONTEND_PORT)"
	@echo "Backend:  http://127.0.0.1:$(FX_BACKEND_PORT)"
	@echo ""
	@echo "Press Ctrl+C to stop both services."
	@trap 'echo ""; echo "Stopping services..."; kill 0' EXIT INT TERM; \
	$(MAKE) -f $(MAKEFILE_NAME) fx-backend & \
	BACKEND_PID=$$!; \
	sleep 2; \
	$(MAKE) -f $(MAKEFILE_NAME) fx-frontend & \
	FRONTEND_PID=$$!; \
	wait $$BACKEND_PID $$FRONTEND_PID

fx-run: fx

fx-build:
	docker build -t $(FX_DOCKER_IMAGE) $(FX_DIR)

fx-docker-run:
	docker run --rm -p $(FX_BACKEND_PORT):5001 --name $(FX_DOCKER_IMAGE) $(FX_DOCKER_IMAGE)

fx-smoke:
	@echo "Checking backend on http://127.0.0.1:$(FX_BACKEND_PORT)"
	@curl -fsS http://127.0.0.1:$(FX_BACKEND_PORT)/ || (echo "Backend check failed" && exit 1)
	@echo ""
	@echo "Checking frontend on http://127.0.0.1:$(FX_FRONTEND_PORT)"
	@curl -fsS http://127.0.0.1:$(FX_FRONTEND_PORT)/ > /dev/null || (echo "Frontend check failed" && exit 1)
	@echo "FX local smoke check passed"

semantic-setup: $(VENV)/bin/activate
	chmod +x $(SEM_SETUP_SCRIPT)
	cd $(SEM_DIR) && ./setup_local.sh

semantic-install: $(VENV)/bin/activate
	cd $(SEM_FRONTEND_DIR) && $(NPM) install

semantic-backend:
	@set -a; \
	[ -f ./api_keys.env ] && source ./api_keys.env; \
	set +a; \
	PYTHONPATH=. .venv/bin/python -m services.semantic_patient_search.backend.local_server

semantic-frontend:
	cd $(SEM_FRONTEND_DIR) && $(NPM) run dev

semantic-wait:
	@echo "Waiting for semantic backend on :$(SEM_BACKEND_PORT)..."
	@attempts=0; \
	until curl -sf http://127.0.0.1:$(SEM_BACKEND_PORT)/api/health > /dev/null; do \
		attempts=$$((attempts+1)); \
		if [ $$attempts -ge 30 ]; then \
			echo "Semantic backend failed to become ready."; \
			exit 1; \
		fi; \
		sleep 1; \
	done
	@echo "Semantic backend is ready."

semantic: semantic-setup
	@echo "Semantic Patient Search is starting..."
	@echo "Frontend: http://127.0.0.1:$(SEM_FRONTEND_PORT)"
	@echo "Backend:  http://127.0.0.1:$(SEM_BACKEND_PORT)"
	@echo ""
	@echo "Press Ctrl+C to stop both services."
	@trap 'echo ""; echo "Stopping services..."; kill 0' EXIT INT TERM; \
	$(MAKE) -f $(MAKEFILE_NAME) semantic-backend & \
	BACKEND_PID=$$!; \
	$(MAKE) -f $(MAKEFILE_NAME) semantic-wait; \
	$(MAKE) -f $(MAKEFILE_NAME) semantic-frontend & \
	FRONTEND_PID=$$!; \
	wait $$BACKEND_PID $$FRONTEND_PID

semantic-run: semantic

semantic-build:
	docker build -t $(SEM_DOCKER_IMAGE) $(SEM_DIR)

semantic-docker-run:
	docker run --rm -p $(SEM_BACKEND_PORT):5002 --name $(SEM_DOCKER_IMAGE) $(SEM_DOCKER_IMAGE)

semantic-smoke:
	@echo "Checking backend on http://127.0.0.1:$(SEM_BACKEND_PORT)"
	@curl -fsS http://127.0.0.1:$(SEM_BACKEND_PORT)/ || (echo "Backend check failed" && exit 1)
	@echo ""
	@echo "Checking frontend on http://127.0.0.1:$(SEM_FRONTEND_PORT)"
	@curl -fsS http://127.0.0.1:$(SEM_FRONTEND_PORT)/ > /dev/null || (echo "Frontend check failed" && exit 1)
	@echo "Semantic Search local smoke check passed"

# --- ADD THIS BLOCK near other service configs ---

CLAUDE_DIR := services/claude-clinical-protocol-reasoning-engine
CLAUDE_API_DIR := $(CLAUDE_DIR)/backend
CLAUDE_WEB_DIR := $(CLAUDE_DIR)/frontend
CLAUDE_BACKEND_PORT := 8020
CLAUDE_FRONTEND_PORT := 5175


# --- ADD THESE TARGETS near trial/customer sections ---

claude-setup: $(VENV)/bin/activate
	$(PIP) install -r $(CLAUDE_API_DIR)/requirements.txt

claude-install: claude-setup
	cd $(CLAUDE_WEB_DIR) && $(NPM) install

claude-backend: claude-setup
	cd $(CLAUDE_API_DIR) && PYTHONPATH=. $(abspath $(UVICORN)) app.main:app --reload --port $(CLAUDE_BACKEND_PORT)

claude-frontend:
	cd $(CLAUDE_WEB_DIR) && PORT=$(CLAUDE_FRONTEND_PORT) NEXT_PUBLIC_CLAUDE_API_BASE_URL=http://127.0.0.1:$(CLAUDE_BACKEND_PORT) $(NPM) run dev
	
claude-wait:
	@echo "Waiting for Claude backend on :$(CLAUDE_BACKEND_PORT)..."
	@attempts=0; \
	until curl -sf http://127.0.0.1:$(CLAUDE_BACKEND_PORT)/health > /dev/null; do \
		attempts=$$((attempts+1)); \
		if [ $$attempts -ge 30 ]; then \
			echo "Claude backend failed to become ready."; \
			exit 1; \
		fi; \
		sleep 1; \
	done
	@echo "Claude backend is ready."

claude: claude-install
	@echo "Claude Clinical Protocol Reasoning Engine is starting..."
	@echo "Frontend: http://127.0.0.1:$(CLAUDE_FRONTEND_PORT)"
	@echo "Backend:  http://127.0.0.1:$(CLAUDE_BACKEND_PORT)"
	@echo ""
	@trap 'echo ""; echo "Stopping services..."; kill 0' EXIT INT TERM; \
	$(MAKE) -f $(MAKEFILE_NAME) claude-backend & \
	BACKEND_PID=$$!; \
	$(MAKE) -f $(MAKEFILE_NAME) claude-wait; \
	$(MAKE) -f $(MAKEFILE_NAME) claude-frontend & \
	FRONTEND_PID=$$!; \
	wait $$BACKEND_PID $$FRONTEND_PID

claude-smoke:
	@curl -fsS http://127.0.0.1:$(CLAUDE_BACKEND_PORT)/health > /dev/null || (echo "Backend failed" && exit 1)
	@curl -fsS http://127.0.0.1:$(CLAUDE_FRONTEND_PORT) > /dev/null || (echo "Frontend failed" && exit 1)
	@echo "Claude smoke test passed"

claude-stop:
	@kill -9 $$(lsof -ti :$(CLAUDE_BACKEND_PORT)) 2>/dev/null || true
	@kill -9 $$(lsof -ti :$(CLAUDE_FRONTEND_PORT)) 2>/dev/null || true

trial-setup: $(VENV)/bin/activate
	$(PIP) install -r $(TRIAL_API_REQUIREMENTS)

trial-install: trial-setup
	cd $(TRIAL_WEB_DIR) && $(NPM) install

trial-backend: trial-setup
	cd $(TRIAL_API_DIR) && PYTHONPATH=. $(abspath $(UVICORN)) app.main:app --reload --port $(TRIAL_BACKEND_PORT)

trial-frontend:
	cd $(TRIAL_WEB_DIR) && NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:$(TRIAL_BACKEND_PORT) $(NPM) run dev

trial-wait:
	@echo "Waiting for clinical trial backend on :$(TRIAL_BACKEND_PORT)..."
	@attempts=0; \
	until curl -sf http://127.0.0.1:$(TRIAL_BACKEND_PORT)/trials > /dev/null; do \
		attempts=$$((attempts+1)); \
		if [ $$attempts -ge 30 ]; then \
			echo "Clinical trial backend failed to become ready."; \
			exit 1; \
		fi; \
		sleep 1; \
	done
	@echo "Clinical trial backend is ready."

trial: trial-install
	@echo "Clinical Trial Matching Agent is starting..."
	@echo "Frontend: http://127.0.0.1:$(TRIAL_FRONTEND_PORT)$(TRIAL_FRONTEND_ROUTE)"
	@echo "Backend:  http://127.0.0.1:$(TRIAL_BACKEND_PORT)"
	@echo ""
	@echo "Press Ctrl+C to stop both services."
	@trap 'echo ""; echo "Stopping services..."; kill 0' EXIT INT TERM; \
	$(MAKE) -f $(MAKEFILE_NAME) trial-backend & \
	BACKEND_PID=$$!; \
	$(MAKE) -f $(MAKEFILE_NAME) trial-wait; \
	$(MAKE) -f $(MAKEFILE_NAME) trial-frontend & \
	FRONTEND_PID=$$!; \
	wait $$BACKEND_PID $$FRONTEND_PID

trial-smoke:
	@echo "Checking backend on http://127.0.0.1:$(TRIAL_BACKEND_PORT)"
	@curl -fsS http://127.0.0.1:$(TRIAL_BACKEND_PORT)/trials > /dev/null || (echo "Backend check failed" && exit 1)
	@echo ""
	@echo "Checking frontend on http://127.0.0.1:$(TRIAL_FRONTEND_PORT)$(TRIAL_FRONTEND_ROUTE)"
	@curl -fsS http://127.0.0.1:$(TRIAL_FRONTEND_PORT)$(TRIAL_FRONTEND_ROUTE) > /dev/null || (echo "Frontend check failed" && exit 1)
	@echo "Clinical Trial local smoke check passed"

trial-stop:
	@kill -9 $$(lsof -ti :$(TRIAL_BACKEND_PORT)) 2>/dev/null || true
	@kill -9 $$(lsof -ti :$(TRIAL_FRONTEND_PORT)) 2>/dev/null || true

customer-setup: $(VENV)/bin/activate
	$(PIP) install fastapi uvicorn python-dotenv

customer-install: customer-setup
	cd $(CUSTOMER_WEB_DIR) && $(NPM) install

customer-backend: customer-setup
	cd $(CUSTOMER_API_DIR) && PYTHONPATH=. $(abspath $(UVICORN)) main:app --reload --port $(CUSTOMER_BACKEND_PORT)

customer-frontend:
	cd $(CUSTOMER_WEB_DIR) && PORT=$(CUSTOMER_FRONTEND_PORT) NEXT_PUBLIC_CUSTOMER_LIFECYCLE_API_BASE_URL=http://127.0.0.1:$(CUSTOMER_BACKEND_PORT) $(NPM) run dev

customer-wait:
	@echo "Waiting for customer lifecycle backend on :$(CUSTOMER_BACKEND_PORT)..."
	@attempts=0; \
	until curl -sf http://127.0.0.1:$(CUSTOMER_BACKEND_PORT)/health > /dev/null; do \
		attempts=$$((attempts+1)); \
		if [ $$attempts -ge 30 ]; then \
			echo "Customer Lifecycle backend failed to become ready."; \
			exit 1; \
		fi; \
		sleep 1; \
	done
	@echo "Customer Lifecycle backend is ready."

customer: customer-install
	@echo "Agentic Customer Lifecycle Platform is starting..."
	@echo "Frontend: http://127.0.0.1:$(CUSTOMER_FRONTEND_PORT)$(CUSTOMER_FRONTEND_ROUTE)"
	@echo "Backend:  http://127.0.0.1:$(CUSTOMER_BACKEND_PORT)"
	@echo ""
	@echo "Press Ctrl+C to stop both services."
	@trap 'echo ""; echo "Stopping services..."; kill 0' EXIT INT TERM; \
	$(MAKE) -f $(MAKEFILE_NAME) customer-backend & \
	BACKEND_PID=$$!; \
	$(MAKE) -f $(MAKEFILE_NAME) customer-wait; \
	$(MAKE) -f $(MAKEFILE_NAME) customer-frontend & \
	FRONTEND_PID=$$!; \
	wait $$BACKEND_PID $$FRONTEND_PID

customer-smoke:
	@echo "Checking backend on http://127.0.0.1:$(CUSTOMER_BACKEND_PORT)"
	@curl -fsS http://127.0.0.1:$(CUSTOMER_BACKEND_PORT)/health > /dev/null || (echo "Backend check failed" && exit 1)
	@echo ""
	@echo "Checking frontend on http://127.0.0.1:$(CUSTOMER_FRONTEND_PORT)$(CUSTOMER_FRONTEND_ROUTE)"
	@curl -fsS http://127.0.0.1:$(CUSTOMER_FRONTEND_PORT)$(CUSTOMER_FRONTEND_ROUTE) > /dev/null || (echo "Frontend check failed" && exit 1)
	@echo "Customer Lifecycle local smoke check passed"

customer-stop:
	@kill -9 $$(lsof -ti :$(CUSTOMER_BACKEND_PORT)) 2>/dev/null || true
	@kill -9 $$(lsof -ti :$(CUSTOMER_FRONTEND_PORT)) 2>/dev/null || true

check: $(VENV)/bin/activate
	@echo "Python:"
	@$(PY) --version
	@echo ""
	@echo "Key packages:"
	@$(PIP) show fastapi uvicorn Flask asgiref requests openai python-docx PyPDF2 || true

clean:
	rm -rf $(VENV)

fx-clean:
	rm -rf $(FX_FRONTEND_DIR)/node_modules
	rm -rf $(FX_FRONTEND_DIR)/dist

semantic-clean:
	rm -rf $(SEM_FRONTEND_DIR)/node_modules
	rm -rf $(SEM_FRONTEND_DIR)/dist

trial-clean:
	rm -rf $(TRIAL_WEB_DIR)/node_modules
	rm -rf $(TRIAL_WEB_DIR)/.next

customer-clean:
	rm -rf $(CUSTOMER_WEB_DIR)/node_modules
	rm -rf $(CUSTOMER_WEB_DIR)/.next

.PHONY: help setup install gateway resume \
	fx-setup fx-install fx-backend fx-frontend fx fx-run fx-build fx-docker-run fx-smoke fx-clean \
	semantic-setup semantic-install semantic-backend semantic-frontend semantic semantic-run semantic-build semantic-docker-run semantic-smoke semantic-clean \
	thermo trial-setup trial-install trial-backend trial-frontend trial-wait trial trial-smoke trial-stop trial-clean \
	customer-setup customer-install customer-backend customer-frontend customer-wait customer customer-smoke customer-stop customer-clean \
	check clean